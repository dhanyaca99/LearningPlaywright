// slicing and combining

let arr = [1, 2, 3, 4, 5];

console.log(arr.slice(1, 3)); //starts at 1 index end at 3 index
console.log(arr.slice(3, 4)); //4
console.log(arr.slice(-1));

//concatenation

let a = [1, 2];
let b = [3, 4];
//let c = a.concat(b);
let c = a.concat(b, [5, 6])
console.log(c);

// spread concatenation
let d = [...a, ...b];
console.log(d);

//join
let s = ["pass", "fail", "skip"].join(" | ");
console.log(s);